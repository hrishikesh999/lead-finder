# YouTube Data API v3 key (console.cloud.google.com → APIs & Services → Credentials)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Anthropic API key (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Hunter.io API key (hunter.io → Dashboard → API)
HUNTER_API_KEY=your_hunter_api_key_here

# Google Sheets — the spreadsheet ID from the sheet URL
# e.g. https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# Google service account credentials JSON (entire JSON blob as a single-line string)
# 1. Google Cloud Console → IAM → Service Accounts → Create
# 2. Enable Google Sheets API + Google Drive API
# 3. Create a JSON key and download it
# 4. Minify: python -c "import json,sys; print(json.dumps(json.load(open('creds.json'))))"
# 5. Paste the minified result below (no newlines)
GOOGLE_SHEETS_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Neon PostgreSQL connection string
# Neon dashboard → Connection Details → copy the connection string
NEON_DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# --- Optional tuning (defaults shown) ---
MIN_YOUTUBE_SUBSCRIBERS=10000
MIN_EMAIL_CONFIDENCE=80
MAX_CANDIDATES_PER_RUN=400
ALLOWED_COUNTRIES=US,CA
CLAUDE_MODEL=claude-haiku-4-5-20251001
LOG_LEVEL=INFO
